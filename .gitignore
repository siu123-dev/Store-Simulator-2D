name=.gitignore
# Unity generated folders
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/UserSettings/

# OS files
.DS_Store
Thumbs.db

# Visual Studio / Rider
.vscode/
*.csproj
*.unityproj
*.sln
*.suo
*.user
*.userprefs
*.pidb
*.booproj
*.svd

# Crash reports and memory snapshots
sysinfo.txt
*.stacktrace

# Keystore (uncomment if you have it locally)
#*.keystore

# Build outputs (don't commit builds)
# /Build/